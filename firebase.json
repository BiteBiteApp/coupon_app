{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "coupon-app-29446",
          "appId": "1:253983587346:android:750437c485d3b0db48accb",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "coupon-app-29446",
          "configurations": {
            "ios": "1:253983587346:ios:9002570d04bd127748accb"
          }
        }
      },
      "ios": {
        "default": {
          "projectId": "coupon-app-29446",
