rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAllowedImage() {
      return request.resource != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function isSharedMenuOwner(menuId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/restaurant_menus/$(menuId))
        && firestore.get(/databases/(default)/documents/restaurant_menus/$(menuId)).data.createdByUserId == request.auth.uid;
    }

    function dishExists(dishId) {
      return firestore.exists(/databases/(default)/documents/bitescore_dishes/$(dishId));
    }

    match /bitesaver_restaurants/{uid}/restaurant_images/{fileName} {
      allow read: if true;
      allow create: if isOwner(uid) && isAllowedImage();
      allow update: if isOwner(uid) && isAllowedImage();
      allow delete: if isOwner(uid);
    }

    match /bitesaver_restaurants/{uid}/coupon_images/{fileName} {
      allow read: if true;
      allow create: if isOwner(uid) && isAllowedImage();
      allow update: if isOwner(uid) && isAllowedImage();
      allow delete: if isOwner(uid);
    }

    match /bitesaver_restaurants/{uid}/menu_images/{fileName} {
      allow read: if true;
      allow create: if isOwner(uid) && isAllowedImage();
      allow update: if isOwner(uid) && isAllowedImage();
      allow delete: if isOwner(uid);
    }

    match /restaurant_menus/{menuId}/menu_images/{fileName} {
      allow read: if true;
      allow create: if isSharedMenuOwner(menuId) && isAllowedImage();
      allow update: if isSharedMenuOwner(menuId) && isAllowedImage();
      allow delete: if isSharedMenuOwner(menuId);
    }

    match /bitescore_dishes/{dishId}/images/{fileName} {
      allow read: if true;
      allow create: if signedIn() && dishExists(dishId) && isAllowedImage();
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
